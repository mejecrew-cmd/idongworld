{
  "name": "idongworld-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "아이동월드 — Phase 1 POC (v1_260509)",
  "scripts": {
    "dev": "concurrently -n FE,BE -c green,blue \"pnpm --filter frontend dev\" \"pnpm --filter backend dev\"",
    "dev:fe": "pnpm --filter frontend dev",
    "dev:be": "pnpm --filter backend dev",
    "dev:mongo:local": "pnpm --filter backend dev:mongo:local",
    "dev:be:local-mongo": "pnpm --filter backend dev:local-mongo",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:e2e:smoke": "playwright test",
    "check:mongo": "pnpm --filter backend check:mongo",
    "check:mongo:atlas": "pnpm --filter backend check:mongo:atlas",
    "check:backend:model-specs": "pnpm --filter backend check:model-specs",
    "check:backend:migration": "pnpm --filter backend check:migration",
    "check:backend:migration:local-mongo": "pnpm --filter backend check:migration:local-mongo",
    "check:module-actions-smoke": "pnpm --filter backend check:module-actions-smoke",
    "check:frontend:state-route-runtime": "pnpm --filter frontend check:state-route-runtime",
    "check:state-route-static": "pnpm audit:legacy-state && pnpm check:backend:model-specs && pnpm typecheck",
    "check:state-route-runtime": "pnpm audit:legacy-state && pnpm check:backend:migration:local-mongo && pnpm check:frontend:state-route-runtime",
    "check:state-route-runtime:local": "node tools/checks/checkStateRouteRuntimeLocal.mjs",
    "check:live-smoke:local": "node tools/checks/checkLiveSmokeLocal.mjs",
    "smoke:backend:persistence": "pnpm --filter backend smoke:persistence",
    "smoke:backend:state-route-removed": "pnpm --filter backend smoke:state-route-removed",
    "i18n:export": "python tools/i18n/exportCsv.py",
    "i18n:import": "python tools/i18n/importCsv.py",
    "i18n:check": "python tools/i18n/validate.py",
    "shared-data:sync-aidong": "python tools/shared-data/syncAidongMaster.py --write",
    "shared-data:check-aidong": "python tools/shared-data/syncAidongMaster.py --check",
    "audit:persona": "python tools/audit/checkPersonaLeak.py",
    "audit:scenario-catalog": "python tools/audit/checkScenarioCatalog.py",
    "audit:diary-catalog": "python tools/audit/checkDiaryCatalog.py",
    "audit:cutscene-catalog": "pnpm audit:scenario-catalog && pnpm audit:diary-catalog",
    "check:data": "pnpm i18n:check && pnpm audit:persona --silent && pnpm audit:cutscene-catalog && pnpm shared-data:check-aidong",
    "audit:exports": "bash tools/audit/checkExports.sh",
    "audit:legacy-state": "node tools/audit/checkLegacyStateUsage.mjs",
    "audit:module-items": "node tools/audit/checkModuleItems.mjs",
    "audit:module-decor": "node tools/audit/checkModuleDecor.mjs",
    "audit:module-catalogs": "pnpm audit:module-items && pnpm audit:module-decor",
    "resources:stage": "node tools/resources/stageResources.mjs",
    "resources:check": "node tools/resources/ingestResources.mjs --check",
    "resources:ingest": "node tools/resources/ingestResources.mjs",
    "resources:commit": "node tools/resources/ingestResources.mjs --commit"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.1"
  }
}
