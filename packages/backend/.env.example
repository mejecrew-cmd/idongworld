# 📁 backend/.env.example — Firebase Admin + 서버 환경변수 템플릿
# ───────────────────────────────────────────────
# 사용:
#   cp .env.example .env.local
#   .env.local 에 실 키 입력 (Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → JSON)
# 보안:
#   - .env.local 은 .gitignore 에 포함 — 절대 commit 금지
#   - FIREBASE_PRIVATE_KEY 는 \n 이 포함된 멀티라인 — 인용부호 안에 그대로 붙여넣기

PORT=4000
NODE_ENV=development

# Firebase Admin SDK (서비스 계정)
FIREBASE_PROJECT_ID=idongworld-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-dummy@idongworld-dev.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nDUMMY_KEY_REPLACE_ME\n-----END PRIVATE KEY-----\n"

# 세션·CORS
SESSION_SECRET=dummy-replace-with-random-32-chars
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# MongoDB
# 정책: 개발은 local MongoDB를 먼저 사용한다.
# Atlas는 추후 사용할 수도 있는 선택지이며, 사용 확정 전까지 필수 전환 대상으로 보지 않는다.
# 사용이 확정되면 repository/service 코드를 바꾸지 않고 MONGO_URI와 transaction 설정만 바꾸는 것이 목표다.
#
# local MongoDB 기본 port: 27017
# Compass local URI:
#   mongodb://127.0.0.1:27017/idongworld
# Compass local URI with auth:
#   mongodb://admin:PASSWORD@127.0.0.1:27017/idongworld?authSource=admin
# Atlas URI:
#   mongodb+srv://user:pass@cluster.mongodb.net/idongworld?retryWrites=true&w=majority
#
# MONGO_URI가 비어 있으면 backend는 memory repository fallback으로 시작한다.
# local MongoDB 확인:
#   pnpm check:mongo
# Atlas 사용 확정 뒤 전환 직전 확인:
#   MONGO_URI=mongodb+srv://...
#   MONGO_CONNECT_REQUIRED=true
#   pnpm check:mongo:atlas
#
# local standalone MongoDB는 보통 transactionsSupported=false다.
# Atlas 또는 replica set에서 transactionsSupported=true를 확인한 뒤 MONGO_TRANSACTIONS_ENABLED=true로 올린다.
MONGO_URI=mongodb://admin:PASSWORD@127.0.0.1:27017/idongworld?authSource=admin
MONGO_CONNECT_REQUIRED=false
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_TRANSACTIONS_ENABLED=false
