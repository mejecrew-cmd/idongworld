# 📁 frontend/.env.example — Firebase Auth (옵션 A) 환경변수 템플릿
# ───────────────────────────────────────────────
# 사용:
#   cp .env.example .env.local
#   .env.local 에 실 키 입력 (Firebase 콘솔 → 프로젝트 설정 → 일반 → 웹 앱 SDK 구성)
# 보안:
#   - .env.local 은 .gitignore 에 포함 — 절대 commit 금지
#   - VITE_ prefix 만 frontend 에 노출 (Vite 정책)

# Firebase 클라이언트 SDK
VITE_FIREBASE_API_KEY=AIza_DUMMY_KEY_REPLACE_ME
VITE_FIREBASE_AUTH_DOMAIN=idongworld-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=idongworld-dev
VITE_FIREBASE_STORAGE_BUCKET=idongworld-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Social login activation gate
# 기본값은 false다. Google/Twitter 버튼은 화면에 보이지만 준비중으로 동작한다.
# Firebase Console에서 Google/Twitter provider와 redirect domain을 설정한 뒤 true로 바꾼다.
VITE_SOCIAL_LOGIN_ENABLED=false

# Backend API base URL
VITE_API_URL=http://localhost:4000

# Google Analytics 4 (GA4) 측정 ID — DUMMY 시 비활성 (1주차 베타 fallback)
# 발급: https://analytics.google.com → 속성 만들기 → 데이터 스트림 → 측정 ID 'G-XXXXXXXXXX'
VITE_GA4_MEASUREMENT_ID=G-DUMMY-REPLACE-ME
VITE_SPLIT_STATE_SYNC=true
VITE_MODULE_ACTION_API_SYNC=false
